    </header>

    <main class="pp<%= (project.sequence || project.video) ? ' pp-cinematic' : '' %>">
      <% if (project.sequence) { %>
      <!-- ============ SCROLL-SCRUB SEQUENCE HERO ============ -->
      <section class="pp-seq" id="ppSeq"
        data-base="<%= project.sequence.base %>" data-pad="<%= project.sequence.pad %>"
        data-ext="<%= project.sequence.ext %>" data-count="<%= project.sequence.count %>">
        <div class="pp-seq-sticky">
          <img class="pp-seq-fallback" src="<%= project.sequence.poster %>" alt="<%= project.title %>" />
          <canvas class="pp-seq-canvas" id="ppSeqCanvas"></canvas>
          <div class="pp-hero-overlay"></div>
          <div class="container pp-hero-inner" id="ppHeroInner">
            <a href="/#projects" class="pp-back">← All Projects</a>
            <% if (project.status) { %><span class="pp-status"><%= project.status %></span><% } %>
            <span class="pp-type"><%= project.type %></span>
            <h1 class="pp-title"><%= project.title %></h1>
            <div class="pp-hero-actions">
              <a href="/#contact" class="btn-navy">Enquire Now</a>
              <a href="#vision" class="btn-ghost-light">Explore the Project</a>
            </div>
          </div>
          <div class="pp-hero-scroll" aria-hidden="true">
            <span>Scroll to build</span>
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.3"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>
      </section>
      <% } else { %>
      <!-- ============ PROJECT HERO (cinematic) ============ -->
      <section class="pp-hero" id="ppHero">
        <div class="pp-hero-media" id="ppHeroMedia">
          <div class="pp-hero-media-inner">
            <% if (project.video) { %>
            <video id="ppHeroVideo" autoplay muted loop playsinline webkit-playsinline preload="auto" poster="<%= project.image %>">
              <source src="<%= project.video %>" type="video/mp4" />
            </video>
            <% } else { %>
            <img src="<%= project.image %>" alt="<%= project.title %>" />
            <% } %>
          </div>
        </div>
        <div class="pp-hero-overlay"></div>
        <div class="container pp-hero-inner" id="ppHeroInner">
          <a href="/#projects" class="pp-back">← All Projects</a>
          <% if (project.status) { %><span class="pp-status"><%= project.status %></span><% } %>
          <span class="pp-type"><%= project.type %></span>
          <h1 class="pp-title"><%= project.title %></h1>
          <div class="pp-hero-actions">
            <a href="/#contact" class="btn-navy">Enquire Now</a>
            <a href="#vision" class="btn-ghost-light">Explore the Project</a>
          </div>
        </div>
        <div class="pp-hero-scroll" aria-hidden="true">
          <span>Scroll</span>
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.3"><path d="m6 9 6 6 6-6"/></svg>
        </div>
      </section>
      <% } %>

      <!-- ============ FROM VISION TO COMPLETION ============ -->
      <% if (c.process && c.process.items && c.process.items.length) { %>
      <section class="section pp-vision" id="vision">
        <div class="container">
          <div class="label reveal">Construction Journey <span class="label-line"></span></div>
          <h2 class="section-title reveal">From Vision to Completion</h2>
          <p class="pp-vision-lead reveal">Every Bridgeway development moves through a disciplined, transparent build process — from first survey to final handover.</p>
          <div class="pp-stages">
            <% c.process.items.forEach(function (s, i) { %>
            <div class="pp-stage-step reveal build" style="transition-delay: <%= (i % 5) * 0.08 %>s">
              <span class="pp-stage-num"><%= s.num %></span>
              <h3><%= s.title %></h3>
              <p><%= s.description %></p>
            </div>
            <% }); %>
          </div>
        </div>
      </section>
      <% } %>

      <!-- ============ OVERVIEW ============ -->
      <section class="section pp-overview">
        <div class="container pp-overview-grid">
          <div class="pp-overview-main">
            <div class="label reveal">Overview <span class="label-line"></span></div>
            <%
              var paras = (project.longDescription && project.longDescription.trim())
                ? project.longDescription.split(/\n+/) : [project.description];
              paras.forEach(function(par){ if (par && par.trim()) { %>
            <p class="pp-lead reveal"><%= par %></p>
            <% } }); %>
          </div>

          <% if (project.details && project.details.length) { %>
          <aside class="pp-specs reveal build">
            <h3>Project Details</h3>
            <ul>
              <% project.details.forEach(function(d){ %>
              <li><span class="pp-spec-label"><%= d.label %></span><span class="pp-spec-value"><%= d.value %></span></li>
              <% }); %>
            </ul>
          </aside>
          <% } %>
        </div>
      </section>

      <!-- ============ FEATURES ============ -->
      <% if (project.features && project.features.length) { %>
      <section class="section pp-features">
        <div class="container">
          <div class="label reveal">Highlights <span class="label-line"></span></div>
          <h2 class="section-title reveal">Key Features</h2>
          <ul class="pp-feature-grid">
            <% project.features.forEach(function(f, i){ %>
            <li class="reveal build" style="transition-delay: <%= (i % 3) * 0.08 %>s">
              <span class="pp-feat-ic">✦</span><%= f %>
            </li>
            <% }); %>
          </ul>
        </div>
      </section>
      <% } %>

      <!-- ============ GALLERY (3D construction assembly) ============ -->
      <%
        var media = [];
        if (project.gallery && project.gallery.length) media = project.gallery.slice();
        else if (project.image) media = [project.image];
      %>
      <% if (media.length) { %>
      <section class="section pp-gallery-sec">
        <div class="container">
          <div class="label reveal">Gallery <span class="label-line"></span></div>
          <h2 class="section-title reveal">Photos &amp; Renders</h2>
        </div>
        <div class="pp-stage">
          <div class="pp-gallery">
            <% media.forEach(function(url, i){
                 var isVid = /\.(mp4|webm|mov|ogg|m4v)(\?|$)/i.test(url); %>
            <figure class="pp-tile reveal build" style="transition-delay: <%= (i % 4) * 0.1 %>s">
              <% if (isVid) { %>
              <video src="<%= url %>" muted loop playsinline autoplay></video>
              <% } else { %>
              <img src="<%= url %>" alt="<%= project.title %> — image <%= i + 1 %>" loading="lazy" />
              <% } %>
            </figure>
            <% }); %>
          </div>
        </div>
      </section>
      <% } %>

      <!-- ============ CTA ============ -->
      <section class="section pp-cta">
        <div class="container pp-cta-inner reveal">
          <h2>Interested in <%= project.title %>?</h2>
          <p>Speak with our Lahore team about availability, pricing and a private viewing.</p>
          <div class="pp-cta-actions">
            <a href="/#contact" class="btn-navy">Enquire Now</a>
            <a href="tel:<%= c.contact.phone.replace(/\s/g, '') %>" class="btn-outline-dark">Call <%= c.contact.phone %></a>
          </div>
        </div>
      </section>
    </main>

    <!-- ============ FOOTER ============ -->
    <footer class="footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <span class="logo-text footer-logo"><%= c.footer.brandText %></span>
          <p><%= c.footer.description %></p>
        </div>
        <div class="footer-col"><h4>Company</h4><a href="/#about">About Us</a><a href="/#projects">Projects</a><a href="/#services">Services</a><a href="/#why-us">Why Us</a></div>
        <div class="footer-col"><h4>Services</h4><a href="/#services">Development</a><a href="/#services">Apartments</a><a href="/#services">Residential</a><a href="/#services">Commercial</a></div>
        <div class="footer-col"><h4>Contact</h4><a href="tel:<%= c.contact.phone.replace(/\s/g, '') %>"><%= c.contact.phone %></a><a href="mailto:<%= c.contact.email %>"><%= c.contact.email %></a><span><%= c.contact.address %></span></div>
      </div>
      <div class="footer-bottom container">
        <p>© <span id="year"></span> <%= c.site.brandName %>. All rights reserved.</p>
        <p class="footer-socials"><% c.footer.socials.forEach(function(s){ %><a href="<%= s.url %>"><%= s.label %></a><% }); %></p>
      </div>
    </footer>

    <button class="back-to-top" id="backToTop" aria-label="Back to top">↑</button>
    <script src="/script.js"></script>
    <script>
      // Cinematic hero: ensure video plays, then drive a slow scroll-linked
      // parallax (scale up + drift), text fade-out, and an architectural
      // blur/darken transition into the section below.
      (function () {
        var v = document.getElementById('ppHeroVideo');
        if (v) {
          v.muted = true; v.playsInline = true;
          var tryPlay = function () { var p = v.play(); if (p && p.catch) p.catch(function () {}); };
          tryPlay();
          v.addEventListener('canplay', tryPlay);
          document.addEventListener('touchstart', tryPlay, { once: true, passive: true });
        }
        var hero = document.getElementById('ppHero');
        var media = document.getElementById('ppHeroMedia');
        var inner = document.getElementById('ppHeroInner');
        var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!hero || !media || reduce) return;

        var ticking = false;
        function onScroll() {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(function () {
            var h = hero.offsetHeight || window.innerHeight;
            var y = window.scrollY;
            var p = Math.max(0, Math.min(y / h, 1)); // 0 → 1 across the hero
            // Video slowly scales up and drifts upward for depth.
            media.style.transform = 'scale(' + (1 + p * 0.14).toFixed(4) + ') translateY(' + (-(p * 26)).toFixed(2) + 'px)';
            // Gentle blur + darken as the next section arrives.
            media.style.filter = 'brightness(' + (1 - p * 0.45).toFixed(3) + ') blur(' + (p * 4).toFixed(2) + 'px)';
            // Overlay text fades up and out.
            if (inner) {
              inner.style.opacity = Math.max(0, 1 - p * 1.5).toFixed(3);
              inner.style.transform = 'translateY(' + (-(p * 40)).toFixed(2) + 'px)';
            }
            ticking = false;
          });
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll);
        onScroll();
      })();

      // Scroll-scrub sequence hero: the building "constructs" as you scroll.
      (function () {
        var section = document.getElementById('ppSeq');
        var canvas = document.getElementById('ppSeqCanvas');
        if (!section || !canvas) return;
        var sticky = canvas.parentNode;
        var fallback = section.querySelector('.pp-seq-fallback');
        var inner = document.getElementById('ppHeroInner');
        var ctx = canvas.getContext('2d');
        var base = section.getAttribute('data-base');
        var ext = section.getAttribute('data-ext') || '.jpg';
        var padN = parseInt(section.getAttribute('data-pad'), 10) || 3;
        var count = parseInt(section.getAttribute('data-count'), 10) || 0;
        var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
        var dpr = Math.min(window.devicePixelRatio || 1, 2);
        var images = new Array(count);
        var current = -1;

        function padStr(n) { var s = '' + n; while (s.length < padN) s = '0' + s; return s; }
        function nearest(i) {
          if (images[i] && images[i].naturalWidth) return images[i];
          for (var d = 1; d < count; d++) {
            if (images[i - d] && images[i - d].naturalWidth) return images[i - d];
            if (images[i + d] && images[i + d].naturalWidth) return images[i + d];
          }
          return null;
        }
        function drawCover(img) {
          var cw = canvas.width, ch = canvas.height, iw = img.naturalWidth, ih = img.naturalHeight;
          var s = Math.max(cw / iw, ch / ih), w = iw * s, h = ih * s;
          ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
        }
        function draw(i, force) {
          i = Math.max(0, Math.min(count - 1, i));
          if (i === current && !force) return;
          current = i;
          var img = nearest(i);
          if (img) { drawCover(img); if (fallback) fallback.style.opacity = '0'; }
        }
        function resize() {
          var w = sticky.clientWidth, h = sticky.clientHeight;
          canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
          canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
          draw(current < 0 ? 0 : current, true);
        }

        // Preload all frames; draw as soon as the relevant ones arrive.
        for (var k = 0; k < count; k++) {
          (function (k) {
            var im = new Image();
            im.onload = function () { if (k === 0 || Math.abs(k - current) <= 1) draw(current < 0 ? 0 : current, true); };
            im.src = base + padStr(k + 1) + ext;
            images[k] = im;
          })(k);
        }

        resize();
        window.addEventListener('resize', resize);

        if (reduce) {
          // No scrubbing — collapse to a single static frame.
          section.style.height = '100svh';
          var mid = new Image();
          mid.onload = function () { draw(Math.floor(count / 2), true); };
          mid.src = base + padStr(Math.floor(count / 2) + 1) + ext;
          return;
        }

        var ticking = false;
        function onScroll() {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(function () {
            var scrollable = section.offsetHeight - window.innerHeight;
            var p = scrollable > 0 ? (-section.getBoundingClientRect().top) / scrollable : 0;
            p = Math.max(0, Math.min(1, p));
            draw(Math.round(p * (count - 1)));
            if (inner) inner.style.opacity = (p < 0.78 ? 1 : Math.max(0, 1 - (p - 0.78) / 0.22)).toFixed(3);
            ticking = false;
          });
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </body>
</html>
