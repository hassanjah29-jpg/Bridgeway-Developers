    </header>

    <main>
      <!-- ============ HERO ============ -->
      <section class="hero" id="home">
        <video class="hero-video" id="heroVideo" autoplay muted loop playsinline preload="auto"
          poster="<%= c.hero.poster %>">
          <source src="<%= c.hero.video %>" type="video/mp4" />
        </video>
        <div class="hero-overlay" aria-hidden="true"></div>

        <div class="hero-content">
          <span class="hero-eyebrow"><%= c.hero.eyebrow %></span>
          <h1 class="hero-title"><%= c.hero.title %></h1>
          <p class="hero-tagline"><%= c.hero.tagline %></p>
        </div>

        <form class="search-bar" id="searchBar" aria-label="Property search">
          <div class="search-field">
            <label>Property Type</label>
            <select>
              <option>Apartment</option><option>Villa / House</option><option>Commercial</option><option>Plot</option>
            </select>
          </div>
          <div class="search-field">
            <label>Bedrooms</label>
            <select><option>1</option><option>2</option><option>3</option><option>4</option><option>5+</option></select>
          </div>
          <div class="search-field">
            <label>Price Range</label>
            <select><option>Any</option><option>Up to 1 Cr</option><option>1 – 3 Cr</option><option>3 Cr+</option></select>
          </div>
          <div class="search-field">
            <label>Community</label>
            <select><option>DHA</option><option>Bahria Town</option><option>Gulberg</option><option>Johar Town</option></select>
          </div>
          <button type="submit" class="btn-navy search-btn">Search Properties</button>
        </form>

        <a href="#about" class="hero-scroll" aria-label="Scroll down">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.4"><path d="m6 9 6 6 6-6"/></svg>
        </a>
        <button class="hero-mute" id="heroMute" aria-label="Toggle sound">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5Z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
        </button>
      </section>

      <!-- ============ INTRO / ABOUT ============ -->
      <section class="section intro" id="about">
        <div class="container">
          <% c.about.leadParagraphs.forEach(function(p){ %>
          <p class="intro-lead reveal"><%= p %></p>
          <% }); %>

          <div class="intro-stats reveal">
            <% c.about.stats.forEach(function(s){ %>
            <div class="istat"><span class="istat-num" data-target="<%= s.target %>" data-suffix="<%= s.suffix %>">0</span><span class="istat-label"><%= s.label %></span></div>
            <% }); %>
          </div>
        </div>
      </section>

      <!-- ============ FEATURED PROJECTS (carousel) ============ -->
      <section class="section projects" id="projects">
        <div class="container">
          <div class="label reveal"><%= c.projects.label %> <span class="label-line"></span></div>
          <div class="section-bar reveal">
            <h2 class="section-title"><%= c.projects.heading %></h2>
            <div class="carousel-nav">
              <button class="carousel-arrow" id="prevProj" aria-label="Previous">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m15 18-6-6 6-6"/></svg>
              </button>
              <button class="carousel-arrow" id="nextProj" aria-label="Next">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m9 18 6-6-6-6"/></svg>
              </button>
            </div>
          </div>
        </div>

        <div class="carousel" id="projCarousel">
          <% c.projects.items.forEach(function(p){ %>
          <article class="slide">
            <div class="slide-img">
              <% if (p.video) { %>
              <video src="<%= p.video %>" muted loop playsinline autoplay poster="<%= p.image %>"></video>
              <% } else { %>
              <img src="<%= p.image %>" alt="<%= p.title %>" loading="lazy" />
              <% } %>
              <% if (p.status) { %><span class="slide-status"><%= p.status %></span><% } %>
            </div>
            <div class="slide-body"><span class="slide-type"><%= p.type %></span><h3><%= p.title %></h3><p><%= p.description %></p><a href="#contact" class="slide-link">Enquire →</a></div>
          </article>
          <% }); %>
        </div>
      </section>

      <!-- ============ SERVICES ============ -->
      <section class="section services" id="services">
        <div class="container">
          <div class="label reveal"><%= c.services.label %> <span class="label-line"></span></div>
          <h2 class="section-title reveal"><%= c.services.heading %></h2>
          <div class="svc-grid">
            <% c.services.items.forEach(function(s){ %>
            <article class="svc reveal"><span class="svc-no"><%= s.no %></span><h3><%= s.title %></h3><p><%= s.description %></p></article>
            <% }); %>
          </div>
        </div>
      </section>

      <!-- ============ WHY CHOOSE US ============ -->
      <section class="section why-us" id="why-us">
        <div class="container">
          <div class="label reveal"><%= c.whyUs.label %> <span class="label-line"></span></div>
          <h2 class="section-title reveal"><%= c.whyUs.heading %></h2>
          <div class="why-grid">
            <% c.whyUs.items.forEach(function(w){ %>
            <div class="why reveal"><h3><%= w.title %></h3><p><%= w.description %></p></div>
            <% }); %>
          </div>
        </div>
      </section>

      <!-- ============ PROCESS ============ -->
      <section class="section process" id="process">
        <div class="container">
          <div class="label reveal"><%= c.process.label %> <span class="label-line"></span></div>
          <h2 class="section-title reveal"><%= c.process.heading %></h2>
          <div class="steps">
            <% c.process.items.forEach(function(s){ %>
            <div class="step reveal"><span class="step-num"><%= s.num %></span><h3><%= s.title %></h3><p><%= s.description %></p></div>
            <% }); %>
          </div>
        </div>
      </section>

      <!-- ============ TESTIMONIALS ============ -->
      <section class="section testimonials">
        <div class="container">
          <div class="label reveal"><%= c.testimonials.label %> <span class="label-line"></span></div>
          <h2 class="section-title reveal"><%= c.testimonials.heading %></h2>
          <div class="quote-grid">
            <% c.testimonials.items.forEach(function(t){ %>
            <figure class="quote reveal"><blockquote><%= t.quote %></blockquote><figcaption><strong><%= t.name %></strong><span><%= t.role %></span></figcaption></figure>
            <% }); %>
          </div>
        </div>
      </section>

      <!-- ============ CONTACT ============ -->
      <section class="section contact" id="contact">
        <div class="container contact-grid">
          <div class="contact-intro">
            <div class="label"><%= c.contact.label %> <span class="label-line"></span></div>
            <h2 class="section-title"><%- c.contact.heading %></h2>
            <p><%= c.contact.intro %></p>
            <ul class="contact-list">
              <li><span>Call</span><a href="tel:<%= c.contact.phone.replace(/\s/g, '') %>"><%= c.contact.phone %></a></li>
              <li><span>Email</span><a href="mailto:<%= c.contact.email %>"><%= c.contact.email %></a></li>
              <li><span>Visit</span><address><%= c.contact.address %></address></li>
            </ul>
          </div>

          <div class="contact-form-wrap">
            <form id="contactForm" novalidate>
              <div class="form-row">
                <div class="field"><label for="name">Full Name</label><input type="text" id="name" name="name" placeholder="Your name" /><small class="err"></small></div>
                <div class="field"><label for="phone">Phone</label><input type="tel" id="phone" name="phone" placeholder="+92 3xx xxxxxxx" /><small class="err"></small></div>
              </div>
              <div class="field"><label for="email">Email</label><input type="email" id="email" name="email" placeholder="you@example.com" /><small class="err"></small></div>
              <div class="field"><label for="message">Message</label><textarea id="message" name="message" rows="4" placeholder="Tell us about your project..."></textarea><small class="err"></small></div>
              <button type="submit" class="btn-navy full">Send Enquiry</button>
            </form>
            <div class="form-success" id="formSuccess" hidden>
              <span class="success-icon">✓</span>
              <h3>Thank you — enquiry received</h3>
              <p>Our team will get back to you within one business day.</p>
              <button type="button" class="btn-outline-dark" id="resetForm">Send another message</button>
            </div>
          </div>
        </div>

        <div class="map" id="map">
          <iframe title="Bridgeway Developers location in Lahore"
            src="<%= c.contact.mapEmbed %>"
            loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </section>
    </main>

    <!-- ============ FOOTER ============ -->
    <footer class="footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <span class="logo-text footer-logo"><%= c.footer.brandText %></span>
          <p><%= c.footer.description %></p>
        </div>
        <div class="footer-col"><h4>Company</h4><a href="#about">About Us</a><a href="#projects">Projects</a><a href="#services">Services</a><a href="#why-us">Why Us</a></div>
        <div class="footer-col"><h4>Services</h4><a href="#services">Development</a><a href="#services">Apartments</a><a href="#services">Residential</a><a href="#services">Commercial</a></div>
        <div class="footer-col"><h4>Contact</h4><a href="tel:<%= c.contact.phone.replace(/\s/g, '') %>"><%= c.contact.phone %></a><a href="mailto:<%= c.contact.email %>"><%= c.contact.email %></a><span><%= c.contact.address %></span></div>
      </div>
      <div class="footer-bottom container">
        <p>© <span id="year"></span> <%= c.site.brandName %>. All rights reserved.</p>
        <p class="footer-socials"><% c.footer.socials.forEach(function(s){ %><a href="<%= s.url %>"><%= s.label %></a><% }); %></p>
      </div>
    </footer>

    <button class="back-to-top" id="backToTop" aria-label="Back to top">↑</button>
    <script src="script.js"></script>
  </body>
</html>
